FROM node:22-alpine

WORKDIR /app

# Install deps first — cached layer
COPY package*.json ./
RUN npm ci

# Copy source (key directories are bind-mounted in dev compose for hot-reload)
COPY . .

# Bind to all interfaces so Docker port-forwarding works
ENV HOSTNAME=0.0.0.0

EXPOSE 3001

CMD ["npm", "run", "dev"]
